DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/agentsys"

# Use postgres for real persistence. Use memory only for smoke tests.
CHECKPOINT_BACKEND="postgres"

# Real mode: set a server-side OpenAI key and keep MOCK_AI=false.
# Smoke mode: set MOCK_AI=true and CHECKPOINT_BACKEND=memory.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
MOCK_AI=false

# Optional. Empty value makes web_search return mock results.
TAVILY_API_KEY=""
