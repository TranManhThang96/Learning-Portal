APP_NAME="AI Backend Service"
DEBUG=true
SECRET_KEY="change-me-use-openssl-rand-hex-32"

DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/aibackend"
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

REDIS_URL="redis://localhost:6379"
REDIS_TTL=3600

QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION="documents"
EMBEDDING_DIM=1536

# Real mode: set a server-side OpenAI key and keep MOCK_AI=false.
# Smoke mode: set MOCK_AI=true to use deterministic local embeddings and
# avoid OpenAI calls. Do not use smoke mode to evaluate answer quality.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-ada-002"
MOCK_AI=false

RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
